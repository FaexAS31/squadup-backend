# Django
SECRET_KEY=your-secret-key-here
DEBUG=False

# Database (PostgreSQL)
DB_USER=blitz_user
DB_PASSWORD=your-db-password
DB_NAME=blitz_db
HOST=db
PORT=5432

# Redis
REDIS_HOST=redis

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=/app/core/your-firebase-adminsdk.json

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Docker Compose (set different values per environment)
COMPOSE_PROJECT_NAME=squadup
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8000

# Monitoring (optional)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9090
LOKI_PORT=3100
